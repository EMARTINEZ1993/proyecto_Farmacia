PORT=5000
NODE_ENV=production

# Opción recomendada para PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@host:5432/base_de_datos
# DB_SSL=true

# Opción manual:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=farmacia_db

# Si tu proveedor exige SSL:
# DB_SSL=true

# URL pública del frontend para CORS.
# Puedes agregar varias separadas por coma.
# Ejemplo:
# ALLOWED_ORIGINS=https://tu-frontend.up.railway.app,http://localhost:5173

JWT_SECRET=tu_clave_secreta_super_segura_cambia_esta_en_produccion
